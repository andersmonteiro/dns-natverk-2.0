# Krill RPKI CA — gerado pelo entrypoint a partir de variáveis de ambiente
ip             = "0.0.0.0"
port           = 3000
data_dir       = "/var/krill/data"
auth_token     = "${KRILL_AUTH_TOKEN}"

# URIs públicas — devem apontar para o IP/domínio público do servidor
rsync_base       = "rsync://${KRILL_FQDN}/repo/"
rrdp_service_uri = "https://${KRILL_FQDN}/rrdp/"

log_level = "info"
log_type  = "stderr"
