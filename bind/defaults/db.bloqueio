; Zona de bloqueio — DNS Nätverk Panel
; Todos os domínios bloqueados apontam para esta zona (sinkhole 0.0.0.0)
$TTL 300
@ IN SOA localhost. root.localhost. (
    2026010101   ; serial
    3600         ; refresh
    900          ; retry
    86400        ; expire
    300 )        ; minimum TTL

@ IN NS  localhost.
@ IN A   0.0.0.0
* IN A   0.0.0.0
@ IN AAAA ::
* IN AAAA ::
