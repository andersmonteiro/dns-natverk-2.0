# Copie este arquivo para .env e preencha os valores antes de subir em produção
# cp .env.example .env

# Chave secreta para JWT — gere com: openssl rand -hex 32
SECRET_KEY=changeme-please-set-in-env

# Caminho do querylog do BIND9
BIND_LOG_PATH=/var/log/named/queries.log

# Caminho do rndc
RNDC_PATH=/usr/sbin/rndc

# Portas expostas (somente no modo bridge/dev)
HTTP_PORT=80
HTTPS_PORT=443

# Timezone dos containers
TZ=America/Sao_Paulo

# Krill RPKI CA
# Token de autenticação da API do Krill — gerado automaticamente pelo instalador
KRILL_AUTH_TOKEN=changeme-krill-token
# IP público ou domínio do servidor (usado nas URIs do RRDP e rsync)
KRILL_FQDN=SEU_IP_OU_DOMINIO_AQUI

# IPs públicos do servidor — detectados pelo install.sh, injetados nos containers
SERVER_IPV4=
SERVER_IPV6=
